# 慈濟60週年網站 - 環境變數設定範例
# 複製此檔案為 .env 並修改設定

# === 後台登入 ===
# Dashboard 和 Admin 頁面的登入帳號密碼
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_password

# === 資料庫 ===
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=events_app

# === 服務埠 ===
PORT=80


# === LLM 審查 (祝福語送出前的 AI 審查) ===
# ⚠️ 重要：LLM_API_KEY 自簽發起算約 30 天到期。
#   到期後祝福審查會一律不通過（log 顯示「審查服務未設定 / 暫時無法使用」）。
#   到期前需到 LLM Gateway 後台重新簽發 sk-llm-* key，更新下方數值，再執行：
#       docker compose up -d api      # 正式機服務名為 app：docker compose up -d app
#   （用 restart 不會生效，必須 up -d 重建容器才會讀到新 key）
#   注意：新 key 僅顯示一次，簽發後請立即複製貼到 .env。
LLM_BASE_URL=https://sberecognition.tzuchi-org.tw/functions/v1/llm-proxy/v1/
LLM_API_KEY=sk-llm-xxxx